import "../../../source/roku_modules/rodash/rodash.brs"
import "../../../source/common.bs"

sub init()
  m.pageType = ""
  m.label = m.top.findNode("label")
  m.rowList = m.top.findNode("rowList")
  m.rowList.observeField("rowItemSelected", "onItemSelected")
  m.fadeAnimation = m.top.findNode("fadeAnimation")
  m.fadeInInterpolator = m.top.findNode("fadeInInterpolator")
  m.container = m.top.findNode("container")
end sub

function beforeViewOpen(params = {} as Object) as Dynamic
  api = { data: { carousels: [] } }
  title = ""
  m.pageType = rodash.getString(params, "route.routeConfig.pattern") = "/shows" ? "shows": "movies"
  if m.pageType = "shows" then
    title = "Shows"
    genres = util.getGenreNamesForType("shows")
    for each genre in genres
      api.data.carousels.push(util.getCarouselByGenre(genre, "series"))
    end for
  else if m.pageType = "movies" then
    title = "Movies"
    genres = util.getGenreNamesForType("movies")
    for each genre in genres
      api.data.carousels.push(util.getCarouselByGenre(genre, "movie"))
    end for
  end if

  m.label.text = title

  rowListContent = rodash.createNode("ContentNode")
  if rodash.isNonEmptyAA(api) then
    for each carousel in api["data"]["carousels"]
      if rodash.isNonEmptyArray(carousel["items"]) then
        row = rodash.createNode("ContentNode", {
          "title": carousel["title"],
        })
        for each item in carousel["items"]
          content = rodash.createNode("ContentNode", item)
          row.appendChild(content)
        end for
        rowListContent.appendChild(row)
      end if
    end for
  end if
  m.rowList.itemComponentName = "CatalogScreenItem"
  m.rowList.itemSize = [1800, 440]
  m.rowList.rowItemSize = [[220, 330]]
  m.rowList.rowLabelOffset = [0, 20]
  m.rowList.showRowLabel = [true]
  m.rowList.numRows = 3
  m.rowList.rowItemSpacing = [20, 20]
  m.rowList.content = rowListContent

  m.fadeAnimation.unobserveField("state")
  m.fadeInInterpolator.keyValue = [m.container.opacity, 1]
  m.fadeAnimation.control = "start"
  return promises.resolve(Invalid)
end function

function onRouteUpdate(event = {} as Object) as Dynamic
  print "CatalogScreen onRouteUpdate called" 'bs:disable-line 1001 LINT3012
  return promises.resolve(Invalid)
end function

function onViewResume(params = {} as Object) as Dynamic
  print "VIEW RESUMED", params
  ' If we are coming from a suspended root, jump to the first item
  fromKeepAlive = params?.route?.navigationState?.fromKeepAlive
  fromPopState = params?.route?.navigationState?.fromPopState
  if fromKeepAlive <> Invalid AND fromKeepAlive AND fromPopState <> Invalid AND NOT fromPopState then
    m.rowList.jumpToRowItem = [0, 0]
  end if
  m.fadeAnimation.unobserveField("state")
  m.fadeInInterpolator.keyValue = [m.container.opacity, 1]
  m.fadeAnimation.control = "start"
  return promises.resolve(Invalid)
end function

function beforeViewSuspend(params = {} as Object) as Dynamic
  print "BEFORE VIEW SUSPEND", params

  ' Resolve any prior pending suspend promise first so it can never dangle if a new
  ' navigation interrupts an in-flight fade-out (the router awaits this promise).
  resolveSuspendPromise()

  m.beforeSuspendPromise = promises.create()
  m.fadeInInterpolator.keyValue = [m.container.opacity, 0]
  m.fadeAnimation.observeField("state", "onFadeAnimationStateChanged")
  m.fadeAnimation.control = "start"
  return m.beforeSuspendPromise
end function

sub onFadeAnimationStateChanged(event as Object)
  if event.getData() = "stopped" then
    print "VIEW SUSPEND ANIMATION COMPLETE, RESOLVING SUSPEND PROMISE"
    resolveSuspendPromise()
  end if
end sub

' Resolves the pending suspend promise exactly once and stops observing the animation.
' Idempotent: safe to call from the animation observer, on re-entry, or on teardown.
sub resolveSuspendPromise()
  m.fadeAnimation.unobserveField("state")
  if m.beforeSuspendPromise <> Invalid then
    promise = m.beforeSuspendPromise
    m.beforeSuspendPromise = Invalid
    promises.resolve(true, promise)
  end if
end sub

function onViewSuspend(params = {} as Object) as Dynamic
  print "VIEW SUSPENDED", params
  return promises.resolve(Invalid)
end function

sub onItemSelected(event as Object)
  itemSelected = event.getRoSGNode().content.getChild(event.getData()[0]).getChild(event.getData()[1])
  contentType = "series"
  if m.pageType = "movies" then contentType = "movie"

  sgRouter.navigateTo({ name: "DetailsView", params: { type: contentType, id: itemSelected.id } })
end sub

function handleFocus(data as Object) as Boolean
  if data.routerFocused then
    return m.rowList.setFocus(true)
  end if

  return false
end function
