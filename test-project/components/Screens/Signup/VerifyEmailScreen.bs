sub init()
	m.buttonGroup = m.top.findNode("buttonGroup")
	m.buttonGroup.buttons = ["I've Verified My Email"]
	m.buttonGroup.observeField("buttonSelected", "onButtonPress")
end sub

function handleFocus(data as Object) as Boolean
	if data.routerFocused then
		return m.buttonGroup.setFocus(true)
	end if
	return false
end function

function beforeViewClose(params = Invalid as Dynamic) as Dynamic
	m.buttonGroup.unobserveField("buttonSelected")
	return promises.resolve(Invalid)
end function

sub onButtonPress(event as Object)
	m.global.AuthManager.isEmailVerified = true
	' popToCheckpoint navigates back to the most recent route that called setCheckpoint().
	' The caller is expected to have called sgRouter.setCheckpoint() at the route to return to.
	sgRouter.popToCheckpoint()
end sub
