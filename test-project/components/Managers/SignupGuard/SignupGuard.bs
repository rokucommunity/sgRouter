import "pkg:/source/router.bs"

' A canActivate guard that immediately redirects unauthenticated users to /signup,
' cancelling the attempted navigation. The current path is passed as
' redirectToOnVerify so VerifyEmailScreen can navigate back to it after verification.
function canActivate(route = {} as Object) as Dynamic
	if m.global.AuthManager.isEmailVerified then
		return true
	end if

	ar = sgRouter.getActiveRoute()
	return sgRouter.createRedirectCommand(`/signup?redirectToOnVerify=${ar.path}`)
end function
