import "pkg:/source/router.bs"

' A canActivate guard that allows navigation to proceed so the destination
' lands in the history stack, then redirects to /signup after NavigationEnd.
' This lets VerifyEmailScreen use sgRouter.popTo() to return to the original destination.
function canActivate(route = {} as Object) as Dynamic
	if m.global.AuthManager.isEmailVerified then
		return true
	end if

	ar = sgRouter.getActiveRoute()
	return sgRouter.createRedirectCommand(`/signup?redirectToOnVerify=${ar.path}`)
end function
