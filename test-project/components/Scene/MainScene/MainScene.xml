<?xml version="1.0" encoding="utf-8"?>
<component name="MainScene" extends="Scene">
	<interface>
		<field id="closeApp" type="boolean" alwaysNotify="true" />
		<field id="isReadyToStartTests" type="boolean" value="false" />
	</interface>

	<children>
		<Outlet id="outlet" />

		<Rectangle id="loadingOverlay" visible="false" color="#000000C0" width="1920" height="1080">
			<Label id="loadingOverlayText" text="Loading..." color="#FFFFFF" width="1920"
				horizAlign="center" translation="[0, 500]" />
		</Rectangle>
		<MainMenu id="mainMenu" visible="false" />

		<Group id="canDeactivateHud" translation="[1200, 20]">
			<Rectangle color="#000000C0" width="500" height="52" />
			<Label id="canDeactivateHudLabel" text="[Replay] canDeactivate: ON" color="#FFFFFF"
				width="500" horizAlign="center" translation="[0, 14]" />
		</Group>
	</children>
</component>