                routeConfigOverrides: {}
            })
        end function

        '+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
        @describe("setCheckpoint")
        '+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

        @async()
        @it("enables popToCheckpoint to find the route by identifier")
        function _() 'bs:disable-line 1026 LINT1026
            m.router@._initialize({ outlet: m.outlet })
            m.router@._addRoutes([
                { pattern: "/alpha", component: "View" }
                { pattern: "/beta", component: "View" }
                { pattern: "/gamma", component: "View" }
            ])
            return promises.chain(sgRouter.navigateTo("/alpha", { router: m.router }), m).then(function(_, m)
                return sgRouter.navigateTo("/beta", { router: m.router })
            end function).then(function(_, m)
                sgRouter.setCheckpoint("foo", { router: m.router })
                return sgRouter.navigateTo("/gamma", { router: m.router })
            end function).then(function(_, m)
                return sgRouter.popToCheckpoint("foo", { router: m.router })
            end function).then(function(_, m)
                m.assertEqual(m.router.routerState.url, "/beta")
                m.assertEqual(m.outlet.findNode("viewTarget").getChildCount(), 2)
            end function).toPromise()
        end function

        @async()
        @it("pops to a checkpointed keepAlive view whose node id was reassigned by a later resume")
        function _() 'bs:disable-line 1026 LINT1026
            ' Regression: a keepAlive view that is resumed by a later forward navigation has its
            ' node id reassigned (the old id is tracked in previousNodeIds). A checkpoint set on the
            ' view's original stack entry still points at the now-stale id, so popToCheckpoint must
            ' resolve the target via previousNodeIds rather than rejecting with "view not found".
            m.router@._initialize({ outlet: m.outlet })
            m.router@._addRoutes([
                { pattern: "/home", component: "View", keepAlive: { enabled: true } }
                { pattern: "/list", component: "View" }
                { pattern: "/detail", component: "View" }
            ])
            return promises.chain(sgRouter.navigateTo("/home", { router: m.router }), m).then(function(_, m)
                ' Checkpoint /home while it is the active view (stack entry records /home's first id)
                sgRouter.setCheckpoint("cp", { router: m.router })
                return sgRouter.navigateTo("/list", { router: m.router })
            end function).then(function(_, m)
                ' Forward-navigate back to /home: it is resumed from the detach store and its node id
                ' is reassigned, leaving the checkpoint entry pointing at the old (now stale) id
                return sgRouter.navigateTo("/home", { router: m.router })
            end function).then(function(_, m)
                return sgRouter.navigateTo("/detail", { router: m.router })
            end function).then(function(_, m)
                return sgRouter.popToCheckpoint("cp", { router: m.router })
            end function).then(function(_, m)
                ' Resolves to the live /home node instead of rejecting, and unwinds /list + /detail
                m.assertEqual(m.router.routerState.url, "/home")
                m.assertEqual(m.outlet.findNode("viewTarget").getChildCount(), 1)
                ' Stack is back at the checkpoint: a further goBack has nowhere to go
                m.assertFalse(sgRouter.goBack({ router: m.router }))
            end function).toPromise()
        end function

        @async()
        @it("uses active route path as identifier when called without argument")
        function _() 'bs:disable-line 1026 LINT1026
            m.router@._initialize({ outlet: m.outlet })
            m.router@._addRoutes([
                { pattern: "/alpha", component: "View" }
                { pattern: "/beta", component: "View" }
                { pattern: "/gamma", component: "View" }
            ])
            return promises.chain(sgRouter.navigateTo("/alpha", { router: m.router }), m).then(function(_, m)
                return sgRouter.navigateTo("/beta", { router: m.router })
            end function).then(function(_, m)
                ' setCheckpoint() with no identifier uses the active route path "/beta"
                sgRouter.setCheckpoint("__INVALID__", { router: m.router })
                return sgRouter.navigateTo("/gamma", { router: m.router })
            end function).then(function(_, m)
                return sgRouter.popToCheckpoint("/beta", { router: m.router })
            end function).then(function(_, m)
                m.assertEqual(m.router.routerState.url, "/beta")
            end function).toPromise()
        end function

        @async()
        @it("is idempotent — duplicate identifier on same route is ignored")
        function _() 'bs:disable-line 1026 LINT1026
            m.router@._initialize({ outlet: m.outlet })
            m.router@._addRoutes([
                { pattern: "/alpha", component: "View" }
                { pattern: "/beta", component: "View" }
                { pattern: "/gamma", component: "View" }
            ])
            return promises.chain(sgRouter.navigateTo("/alpha", { router: m.router }), m).then(function(_, m)
                return sgRouter.navigateTo("/beta", { router: m.router })
            end function).then(function(_, m)
                sgRouter.setCheckpoint("foo", { router: m.router })
                sgRouter.setCheckpoint("foo", { router: m.router })
                return sgRouter.navigateTo("/gamma", { router: m.router })
            end function).then(function(_, m)
                return sgRouter.popToCheckpoint("foo", { router: m.router })
            end function).then(function(_, m)
                m.assertEqual(m.router.routerState.url, "/beta")
            end function).toPromise()
        end function

        @async()
        @it("supports multiple identifiers on the same route")
        function _() 'bs:disable-line 1026 LINT1026
            m.router@._initialize({ outlet: m.outlet })
            m.router@._addRoutes([
                { pattern: "/alpha", component: "View" }
                { pattern: "/beta", component: "View" }
                { pattern: "/gamma", component: "View" }
            ])
            return promises.chain(sgRouter.navigateTo("/alpha", { router: m.router }), m).then(function(_, m)
                return sgRouter.navigateTo("/beta", { router: m.router })
            end function).then(function(_, m)
                sgRouter.setCheckpoint("foo", { router: m.router })
                sgRouter.setCheckpoint("bar", { router: m.router })
                return sgRouter.navigateTo("/gamma", { router: m.router })
            end function).then(function(_, m)
                ' Both "foo" and "bar" are registered on /beta; pop by "bar" resolves to /beta
                return sgRouter.popToCheckpoint("bar", { router: m.router })
            end function).then(function(_, m)
                m.assertEqual(m.router.routerState.url, "/beta")
            end function).toPromise()
        end function

        @async()
        @it("second identifier on route remains after popping by the first")
        function _() 'bs:disable-line 1026 LINT1026
            m.router@._initialize({ outlet: m.outlet })
            m.router@._addRoutes([
                { pattern: "/alpha", component: "View" }
                { pattern: "/beta", component: "View" }
                { pattern: "/gamma", component: "View" }
                { pattern: "/delta", component: "View" }
            ])
            return promises.chain(sgRouter.navigateTo("/alpha", { router: m.router }), m).then(function(_, m)
                return sgRouter.navigateTo("/beta", { router: m.router })
            end function).then(function(_, m)
                sgRouter.setCheckpoint("foo", { router: m.router })
                sgRouter.setCheckpoint("bar", { router: m.router })
                return sgRouter.navigateTo("/gamma", { router: m.router })
            end function).then(function(_, m)
                ' popToCheckpoint("foo") should also resolve to /beta (same route as "bar")
                return sgRouter.popToCheckpoint("foo", { router: m.router })
            end function).then(function(_, m)
                m.assertEqual(m.router.routerState.url, "/beta")
            end function).toPromise()
        end function

        @async()
        @it("does nothing and popToCheckpoint rejects when stack was empty at setCheckpoint time")
        function _() 'bs:disable-line 1026 LINT1026
            m.router@._initialize({ outlet: m.outlet })
            m.router@._addRoutes([
                { pattern: "/alpha", component: "View" }
                { pattern: "/beta", component: "View" }
            ])
            ' setCheckpoint before any navigation — stack is empty, should be a no-op
            sgRouter.setCheckpoint("foo", { router: m.router })
            return promises.chain(sgRouter.navigateTo("/alpha", { router: m.router }), m).then(function(_, m)
                return sgRouter.navigateTo("/beta", { router: m.router })
            end function).then(function(_, m)
                return sgRouter.popToCheckpoint("foo", { router: m.router })
            end function).then(function(_, m)
                m.fail("popToCheckpoint should have rejected — no checkpoint registered")
            end function).catch(function(error, m)
                m.assertNotInvalid(error)
            end function).toPromise()
        end function

        '+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
        @describe("popToCheckpoint")
        '+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

        @async()
        @it("queues popToCheckpoint when a navigation is already in progress and runs it after")
        function _() 'bs:disable-line 1026 LINT1026
            m.router@._initialize({ outlet: m.outlet })
            m.router@._addRoutes([
                { pattern: "/alpha", component: "View" }
                { pattern: "/beta", component: "View" }
            ])
            return promises.chain(sgRouter.navigateTo("/alpha", { router: m.router }), m).then(function(_, m)
                sgRouter.setCheckpoint("foo", { router: m.router })
                return sgRouter.navigateTo("/beta", { router: m.router })
            end function).then(function(_, m)
                ' Start a navigation (sets navigationInProgress = true)
                sgRouter.navigateTo("/alpha", { router: m.router })
                ' popToCheckpoint is queued rather than blocked; its deferred resolves after it runs
                return sgRouter.popToCheckpoint("foo", { router: m.router })
            end function).then(function(_, m)
                ' The queued pop ran once the in-flight navigation completed and unwound to /alpha
                activeRoute = sgRouter.getActiveRoute({ router: m.router })
                m.assertEqual(activeRoute.path, "/alpha")
            end function).catch(function(_error, m)
                m.fail("Queued popToCheckpoint should not have been rejected")
            end function).toPromise()
        end function

