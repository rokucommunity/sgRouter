        @async()
        @it("dispatches NavigationStart and NavigationEnd")
        function _() 'bs:disable-line 1026 LINT1026
            m.router@._initialize({ outlet: m.outlet })
            m.router.observeField("routerState", "onRouterStateChanged")
            m.router@._addRoutes([
                { pattern: "/alpha", component: "View" }
                { pattern: "/beta", component: "View" }
                { pattern: "/gamma", component: "View" }
            ])
            return promises.chain(sgRouter.navigateTo("/alpha", { router: m.router }), m).then(function(_, m)
                sgRouter.setCheckpoint("start", { router: m.router })
                return sgRouter.navigateTo("/beta", { router: m.router })
            end function).then(function(_, m)
                return sgRouter.navigateTo("/gamma", { router: m.router })
            end function).then(function(_, m)
                getGlobalAA().routerStatesHistory = []
                return sgRouter.popToCheckpoint("start", { router: m.router })
            end function).then(function(_, m)
                history = getGlobalAA().routerStatesHistory
                m.assertEqual(history[0], "NavigationStart")
                m.assertEqual(history[history.count() - 1], "NavigationEnd")
            end function).toPromise()
        end function

        @async()
        @it("pops to the most recent route with any checkpoint when identifier is omitted")
        function _() 'bs:disable-line 1026 LINT1026
            m.router@._initialize({ outlet: m.outlet })
            m.router@._addRoutes([
                { pattern: "/alpha", component: "View" }
                { pattern: "/beta", component: "View" }
                { pattern: "/gamma", component: "View" }
                { pattern: "/delta", component: "View" }
            ])
            return promises.chain(sgRouter.navigateTo("/alpha", { router: m.router }), m).then(function(_, m)
                sgRouter.setCheckpoint("a", { router: m.router })
                return sgRouter.navigateTo("/beta", { router: m.router })
            end function).then(function(_, m)
                return sgRouter.navigateTo("/gamma", { router: m.router })
            end function).then(function(_, m)
                sgRouter.setCheckpoint("c", { router: m.router })
                return sgRouter.navigateTo("/delta", { router: m.router })
            end function).then(function(_, m)
                ' /gamma is the most recent checkpointed route; pop with no identifier lands there
                return sgRouter.popToCheckpoint("__INVALID__", { router: m.router })
            end function).then(function(_, m)
                m.assertEqual(m.router.routerState.url, "/gamma")
                m.assertEqual(m.outlet.findNode("viewTarget").getChildCount(), 3)
            end function).toPromise()
        end function

        @async()
        @it("pops to the most recent matching checkpoint when multiple routes are checkpointed")
        function _() 'bs:disable-line 1026 LINT1026
            m.router@._initialize({ outlet: m.outlet })
            m.router@._addRoutes([
                { pattern: "/alpha", component: "View" }
                { pattern: "/beta", component: "View" }
                { pattern: "/gamma", component: "View" }
                { pattern: "/delta", component: "View" }
            ])
            return promises.chain(sgRouter.navigateTo("/alpha", { router: m.router }), m).then(function(_, m)
                sgRouter.setCheckpoint("foo", { router: m.router })
                return sgRouter.navigateTo("/beta", { router: m.router })
            end function).then(function(_, m)
                return sgRouter.navigateTo("/gamma", { router: m.router })
            end function).then(function(_, m)
                sgRouter.setCheckpoint("foo", { router: m.router })
                return sgRouter.navigateTo("/delta", { router: m.router })
            end function).then(function(_, m)
                ' Both /alpha and /gamma have "foo"; most recent is /gamma
                return sgRouter.popToCheckpoint("foo", { router: m.router })
            end function).then(function(_, m)
                m.assertEqual(m.router.routerState.url, "/gamma")
                m.assertEqual(m.outlet.findNode("viewTarget").getChildCount(), 3)
            end function).toPromise()
        end function

        @async()
        @it("restores a keepAlive view from the detach store")
        function _() 'bs:disable-line 1026 LINT1026
            m.router@._initialize({ outlet: m.outlet })
            m.router@._addRoutes([
                { pattern: "/alpha", component: "View", keepAlive: { enabled: true } }
                { pattern: "/beta", component: "View" }
                { pattern: "/gamma", component: "View" }
            ])
            return promises.chain(sgRouter.navigateTo("/alpha", { router: m.router }), m).then(function(_, m)
                sgRouter.setCheckpoint("start", { router: m.router })
                return sgRouter.navigateTo("/beta", { router: m.router })
            end function).then(function(_, m)
                ' /alpha is now held in the detach store
                m.assertEqual(m.router@._getDetachedViews().count(), 1)
                return sgRouter.navigateTo("/gamma", { router: m.router })
            end function).then(function(_, m)
                return sgRouter.popToCheckpoint("start", { router: m.router })
            end function).then(function(_, m)
                ' /alpha is restored to viewTarget; the detach store is empty
                m.assertEqual(m.router@._getDetachedViews().count(), 0)
                m.assertEqual(m.outlet.findNode("viewTarget").getChildCount(), 1)
                m.assertEqual(m.router.routerState.url, "/alpha")
            end function).toPromise()
        end function

        @async()
        @it("suspends keepAlive views above target")
        function _() 'bs:disable-line 1026 LINT1026
            m.router@._initialize({ outlet: m.outlet })
            m.router@._addRoutes([
                { pattern: "/alpha", component: "View" }
                { pattern: "/beta", component: "View", keepAlive: { enabled: true } }
                { pattern: "/gamma", component: "View" }
            ])
            return promises.chain(sgRouter.navigateTo("/alpha", { router: m.router }), m).then(function(_, m)
                sgRouter.setCheckpoint("start", { router: m.router })
                return sgRouter.navigateTo("/beta", { router: m.router })
            end function).then(function(_, m)
                return sgRouter.navigateTo("/gamma", { router: m.router })
            end function).then(function(_, m)
                ' /beta is in the detach store
                m.assertEqual(m.router@._getDetachedViews().count(), 1)
                return sgRouter.popToCheckpoint("start", { router: m.router })
            end function).then(function(_, m)
                ' /beta should remain suspended in the detach store, /gamma destroyed
                m.assertEqual(m.router@._getDetachedViews().count(), 1)
                m.assertEqual(m.outlet.findNode("viewTarget").getChildCount(), 1)
                m.assertEqual(m.router.routerState.url, "/alpha")
            end function).toPromise()
        end function

        @async()
        @it("suspends multiple keepAlive views above target")
        function _() 'bs:disable-line 1026 LINT1026
            m.router@._initialize({ outlet: m.outlet })
            m.router@._addRoutes([
                { pattern: "/alpha", component: "View" }
                { pattern: "/beta", component: "View", keepAlive: { enabled: true } }
                { pattern: "/gamma", component: "View", keepAlive: { enabled: true } }
                { pattern: "/delta", component: "View" }
            ])
            return promises.chain(sgRouter.navigateTo("/alpha", { router: m.router }), m).then(function(_, m)
                sgRouter.setCheckpoint("start", { router: m.router })
                return sgRouter.navigateTo("/beta", { router: m.router })
            end function).then(function(_, m)
                return sgRouter.navigateTo("/gamma", { router: m.router })
            end function).then(function(_, m)
                return sgRouter.navigateTo("/delta", { router: m.router })
            end function).then(function(_, m)
                ' /beta and /gamma are suspended in the detach store
                m.assertEqual(m.router@._getDetachedViews().count(), 2)
                return sgRouter.popToCheckpoint("start", { router: m.router })
            end function).then(function(_, m)
                ' /beta and /gamma remain suspended, /delta destroyed
                m.assertEqual(m.router@._getDetachedViews().count(), 2)
                m.assertEqual(m.outlet.findNode("viewTarget").getChildCount(), 1)
                m.assertEqual(m.router.routerState.url, "/alpha")
            end function).toPromise()
        end function

        @async()
        @it("truncates history stack so subsequent goBack returns false")
        function _() 'bs:disable-line 1026 LINT1026
            m.router@._initialize({ outlet: m.outlet })
            m.router@._addRoutes([
                { pattern: "/alpha", component: "View" }
                { pattern: "/beta", component: "View" }
                { pattern: "/gamma", component: "View" }
            ])
            return promises.chain(sgRouter.navigateTo("/alpha", { router: m.router }), m).then(function(_, m)
                sgRouter.setCheckpoint("start", { router: m.router })
                return sgRouter.navigateTo("/beta", { router: m.router })
            end function).then(function(_, m)
                return sgRouter.navigateTo("/gamma", { router: m.router })
            end function).then(function(_, m)
                return sgRouter.popToCheckpoint("start", { router: m.router })
            end function).then(function(_, m)
                ' Stack is now just [/alpha]; goBack has nothing to go back to
                result = sgRouter.goBack({ router: m.router })
                m.assertFalse(result)
            end function).toPromise()
        end function

        @async()
        @it("allows subsequent navigation after completing")
        function _() 'bs:disable-line 1026 LINT1026
            m.router@._initialize({ outlet: m.outlet })
            m.router@._addRoutes([
                { pattern: "/alpha", component: "View" }
                { pattern: "/beta", component: "View" }
                { pattern: "/gamma", component: "View" }
            ])
            return promises.chain(sgRouter.navigateTo("/alpha", { router: m.router }), m).then(function(_, m)
                sgRouter.setCheckpoint("start", { router: m.router })
                return sgRouter.navigateTo("/beta", { router: m.router })
            end function).then(function(_, m)
                return sgRouter.popToCheckpoint("start", { router: m.router })
            end function).then(function(_, m)
                return sgRouter.navigateTo("/gamma", { router: m.router })
            end function).then(function(_, m)
                m.assertEqual(m.router.routerState.url, "/gamma")
            end function).toPromise()
        end function

        @async()
        @it("rejects when identifier does not match any stack entry checkpoint")
        function _() 'bs:disable-line 1026 LINT1026
            m.router@._initialize({ outlet: m.outlet })
            m.router@._addRoutes([
                { pattern: "/alpha", component: "View" }
                { pattern: "/beta", component: "View" }
            ])
            return promises.chain(sgRouter.navigateTo("/alpha", { router: m.router }), m).then(function(_, m)
                sgRouter.setCheckpoint("foo", { router: m.router })
                return sgRouter.navigateTo("/beta", { router: m.router })
            end function).then(function(_, m)
                return sgRouter.popToCheckpoint("bar", { router: m.router })
            end function).then(function(_, m)
                m.fail("popToCheckpoint with non-matching identifier should have rejected")
            end function).catch(function(error, m)
                m.assertNotInvalid(error)
            end function).toPromise()
        end function

        @async()
        @it("does not dispatch navigation events when no checkpoint is found")
        function _() 'bs:disable-line 1026 LINT1026
            m.router@._initialize({ outlet: m.outlet })
            m.router.observeField("routerState", "onRouterStateChanged")
            m.router@._addRoutes([
                { pattern: "/alpha", component: "View" }
                { pattern: "/beta", component: "View" }
            ])
            return promises.chain(sgRouter.navigateTo("/alpha", { router: m.router }), m).then(function(_, m)
                return sgRouter.navigateTo("/beta", { router: m.router })
            end function).then(function(_, m)
                getGlobalAA().routerStatesHistory = []
                return sgRouter.popToCheckpoint("missing", { router: m.router })
            end function).then(function(_, m)
                m.fail("Should have rejected")
            end function).catch(function(error, m)
                m.assertNotInvalid(error)
                m.assertEqual(getGlobalAA().routerStatesHistory, [])
            end function).toPromise()
        end function

        @async()
        @it("rejects when an invalid type is passed as identifier")
        function _() 'bs:disable-line 1026 LINT1026
            m.router@._initialize({ outlet: m.outlet })
            m.router@._addRoutes([
                { pattern: "/alpha", component: "View" }
                { pattern: "/beta", component: "View" }
            ])
            return promises.chain(sgRouter.navigateTo("/alpha", { router: m.router }), m).then(function(_, m)
                sgRouter.setCheckpoint("foo", { router: m.router })
                return sgRouter.navigateTo("/beta", { router: m.router })
            end function).then(function(_, m)
                return sgRouter.popToCheckpoint({ id: "foo" }, { router: m.router })
            end function).then(function(_, m)
                m.fail("popToCheckpoint with non-string identifier should have rejected")
            end function).catch(function(error, m)
                m.assertNotInvalid(error)
            end function).toPromise()
        end function

        '+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
        @describe("getActiveRoute")
        '+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
        @it("returns Invalid when no navigation has occurred yet")
        function _() 'bs:disable-line 1026 LINT1026
            m.router@._initialize({ outlet: m.outlet })
            m.router@._addRoutes([
                { pattern: "/alpha", component: "View" },
            ])

            result = sgRouter.getActiveRoute({ router: m.router })
            m.assertInvalid(result)
        end function

        @async()
        @it("returns the active route after navigation")
        function _() 'bs:disable-line 1026 LINT1026
            m.router@._initialize({ outlet: m.outlet })
            m.router@._addRoutes([
                { pattern: "/alpha", component: "View" },
                { pattern: "/beta", component: "View" },
            ])

            return promises.chain(sgRouter.navigateTo("/alpha", { router: m.router }), m).then(function(_result, m)
                activeRoute = sgRouter.getActiveRoute({ router: m.router })
                m.assertNotInvalid(activeRoute)
                m.assertEqual(activeRoute.path, "/alpha")
            end function).toPromise()
        end function

        @it("returns Invalid when no router is found in the chain")
        function _() 'bs:disable-line 1026 LINT1026
            result = sgRouter.getActiveRoute({ router: Invalid })
            m.assertInvalid(result)
        end function

        '+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
        @describe("getRoutes")
        '+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
        @it("getRoutes")
        function _() 'bs:disable-line 1026 LINT1026
            m.router@._initialize({ outlet: m.outlet })
            sgRouter.addRoutes([
                { pattern: "/alpha", component: "View" },
                { pattern: "/beta", component: "View" },
            ], { router: m.router })

            m.assertEqual(sgRouter.getRoutes({ router: m.router }), {
                "/alpha": {
                    "allowreuse": false
                    "canactivate": []
                    "component": "View"
                    "clearstackonresolve": false
                    "keepalive": { enabled: false }
                    "suspendmode": "hide"
                    "pattern": "/alpha"
                }
                "/beta": {
                    "allowreuse": false
                    "canactivate": []
                    "component": "View"
                    "clearstackonresolve": false
                    "keepalive": { enabled: false }
                    "suspendmode": "hide"
                    "pattern": "/beta"
                }
            })
        end function
    end class
end namespace
