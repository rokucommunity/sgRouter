{
  "name": "@rokucommunity/sgrouter",
  "version": "0.1.0",
  "description": "A router for the Roku platform",
  "main": "index.js",
  "keywords": [
    "ropm",
    "roku"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rokucommunity/sgRouter"
  },
  "homepage": "https://github.com/rokucommunity/sgRouter#readme",
  "bugs": {
    "url": "https://github.com/rokucommunity/sgRouter/issues"
  },
  "scripts": {
    "package": "npx ropm copy && npm run build && npm pack",
    "preversion": "npx ropm copy && npm run build",
    "build": "npm run compile && ts-node ./scripts/createDist.ts",
    "build-tests": "npm run compile -- --project tests/bsconfig.json",
    "compile": "npx bsc",
    "docs": "npm run build && jsdoc -c jsdoc.json -d docs -t ./node_modules/better-docs",
    "build-sample-project": "cd test-project && npx bsc",
    "test": "npx rooibos --project=./tests/bsconfig.json",
    "createDataSet": "ts-node ./scripts/createDataSet.ts"
  },
  "author": "Tyler Smith",
  "license": "MIT",
  "ropm": {
    "packagePrefix": "sgRouter",
    "packageRootDir": "dist",
    "rootDir": "src"
  },
  "devDependencies": {
    "@types/fs-extra": "^9.0.13",
    "@types/lodash": "^4.17.13",
    "@types/node": "^18.7.16",
    "brighterscript": "^0.70.3",
    "dotenv": "^16.4.5",
    "fast-glob": "^3.2.12",
    "fs-extra": "^10.1.0",
    "lodash": "^4.17.23",
    "node-fetch": "^2.7.0",
    "rooibos-roku": "^5.15.7",
    "ropm": "^0.11.4",
    "ts-node": "^10.9.1",
    "typescript": "^4.8.3"
  },
  "dependencies": {
    "promises": "npm:@rokucommunity/promises@^0.3.0",
    "rodash": "npm:@tkss/rodash@^0.0.35"
  }
}
